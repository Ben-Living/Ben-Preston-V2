---
import Base from '../layouts/Base.astro';
import TopographyLines from '../components/TopographyLines.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('field-notes');

// Sort alphabetically by title for a stable, readable order
const notes = allNotes.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Base title="Field Notes" currentPage="/field-notes" navTheme="dark">

  <!-- ── DARK HEADER ──────────────────────────────────────────────────────── -->
  <section class="fn-header">
    <TopographyLines id="topo-fn" theme="dark" />
    <div class="container topo-content fn-header__inner">
      <p class="fn-header__eyebrow">Field Notes</p>
    </div>
  </section>

  <!-- ── INTRO ──────────────────────────────────────────────────────────────── -->
  <section class="fn-intro">
    <div class="container fn-intro__inner">
      <p class="fn-intro__lead reveal">The proposition that forms the foundation of my ideas and my work.</p>
      <div class="fn-intro__body reveal-group">
        <p class="reveal">We are not only a self experiencing the world from the inside. We are also a fractal of that world itself — nested within it, shaped by it, shaping it in return. This is what our best science points to, and what direct experience confirms when we slow down enough to notice.</p>
        <p class="reveal">Most of our problems — in how we lead, how we collaborate, what we build — trace back to a misunderstanding of this. The work is to gently, persistently reorganise our ways of being and acting to reflect what's actually true. When that happens, everything else gets easier.</p>
        <p class="reveal fn-intro__transition">Things I'm thinking about, working through, or want to share. Some of these are essays, some are conversations, some are just notes from the field.</p>
      </div>
    </div>
  </section>

  <!-- ── CARD GRID ──────────────────────────────────────────────────────────── -->
  <section class="fn-grid-section">
    <div class="container">
      <div class="fn-cards">
        {notes.map(note => (
          <a href={`/field-notes/${note.slug}`} class="fn-card">
            {note.data.tags && note.data.tags.length > 0 && (
              <div class="fn-card__tags">
                {note.data.tags.map((tag: string) => (
                  <span class="fn-card__tag">{tag}</span>
                ))}
              </div>
            )}
            <h2 class="fn-card__title">{note.data.title}</h2>
            <p class="fn-card__excerpt">{note.data.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── HEADER ─────────────────────────────────────────────────────────────── */
  .fn-header {
    background: var(--color-charcoal);
    color: var(--color-text-stone);
    padding-top: calc(var(--nav-height) + var(--space-10));
    padding-bottom: var(--space-10);
    position: relative;
    overflow: hidden;
  }

  .fn-header__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .fn-header__eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-sage);
    font-weight: 500;
  }

  /* ── INTRO ───────────────────────────────────────────────────────────────── */
  .fn-intro {
    background: var(--color-stone-soft);
    padding: var(--space-20) 0 var(--space-16);
    border-bottom: 1px solid rgba(45, 42, 38, 0.10);
  }

  .fn-intro__inner {
    max-width: 680px;
  }

  .fn-intro__lead {
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin-bottom: var(--space-8);
    line-height: 1.4;
  }

  .fn-intro__body p {
    font-size: var(--text-md);
    line-height: var(--leading-loose);
    color: rgba(45, 42, 38, 0.75);
  }

  .fn-intro__body p + p {
    margin-top: var(--space-6);
  }

  .fn-intro__transition {
    margin-top: var(--space-10) !important;
    color: rgba(45, 42, 38, 0.55) !important;
    font-size: var(--text-base) !important;
  }

  /* ── GRID SECTION ────────────────────────────────────────────────────────── */
  .fn-grid-section {
    background: var(--color-stone-soft);
    padding: var(--space-16) 0 var(--space-32);
  }

  /* ── CARD GRID ───────────────────────────────────────────────────────────── */
  .fn-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(45, 42, 38, 0.10);
  }

  @media (max-width: 640px) {
    .fn-cards {
      grid-template-columns: 1fr;
    }
  }

  /* ── CARD ────────────────────────────────────────────────────────────────── */
  .fn-card {
    background: var(--color-stone-soft);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-height: 220px;
    text-decoration: none;
    transition: background var(--dur-base);
  }

  .fn-card:hover {
    background: var(--color-stone);
  }

  .fn-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .fn-card__tag {
    font-size: 0.65rem;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-sage);
    font-weight: 500;
  }

  .fn-card__tag + .fn-card__tag::before {
    content: '\00b7';
    margin-right: var(--space-2);
    opacity: 0.5;
  }

  .fn-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 300;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    line-height: 1.25;
    flex: 1;
  }

  .fn-card__excerpt {
    font-size: var(--text-sm);
    color: rgba(45, 42, 38, 0.55);
    line-height: var(--leading-relaxed);
  }
</style>
