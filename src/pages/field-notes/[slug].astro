---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const notes = await getCollection('field-notes');
  return notes.map(n => ({ params: { slug: n.slug }, props: { note: n } }));
}
const { note } = Astro.props;
const { Content } = await note.render();
---
<Base title={note.data.title} currentPage="/field-notes">
  <article>
    <section style="background: var(--color-charcoal); color: var(--color-stone); padding-top: calc(var(--nav-height) + var(--space-20)); padding-bottom: var(--space-16);">
      <div class="container">
        <a href="/field-notes" style="font-size: 0.875rem; color: rgba(242,237,231,0.4); display: inline-block; margin-bottom: var(--space-8); transition: color 0.3s;" onmouseover="this.style.color='rgba(242,237,231,0.9)'" onmouseout="this.style.color='rgba(242,237,231,0.4)'">← Field Notes</a>
        <p style="font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-sage); margin-bottom: var(--space-4);">Field Note</p>
        <h1 style="font-family: var(--font-heading); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 300; letter-spacing: -0.025em; max-width: 700px; margin-bottom: var(--space-6);">{note.data.title}</h1>
        <p style="font-size: 1.125rem; color: rgba(242,237,231,0.55); font-style: italic; max-width: 580px;">{note.data.excerpt}</p>
      </div>
    </section>
    <section style="background: var(--color-stone-soft); padding: var(--space-16) 0 var(--space-32);">
      <div class="container" style="max-width: 640px;">
        <div class="fn-body"><Content /></div>
      </div>
    </section>
  </article>
</Base>
<style>
  .fn-body :global(p) { font-size: 1.125rem; line-height: 1.8; margin-bottom: 2rem; color: rgba(45,42,38,0.82); }
  .fn-body :global(p:first-child) { font-family: var(--font-heading); font-size: clamp(1.2rem, 2vw, 1.45rem); font-weight: 300; line-height: 1.55; letter-spacing: -0.01em; color: var(--color-ink); }
  .fn-body :global(em) { font-style: italic; }
</style>
